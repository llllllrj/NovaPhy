</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">q</parametername>
</parameternamelist>
<parameterdescription>
<para>Generalized positions. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>Joint-space inertia matrix H(q), size nv x nv, symmetric positive definite.</para>
</simplesect>
<simplesect kind="note"><para>Typical complexity is O(n^2) for tree articulations.</para>
</simplesect>
<parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">model</parametername>
</parameternamelist>
